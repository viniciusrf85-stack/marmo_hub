# ============================================
# CONFIGURAÇÃO DO SERVIDOR
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# BANCO DE DADOS
# ============================================
# IMPORTANTE: Configure as credenciais do seu MySQL
# Não use credenciais padrão em produção!
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=olx_pedra

# ============================================
# AUTENTICAÇÃO JWT
# ============================================
# Gere uma chave segura com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_EXPIRES_IN=7d

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# UPLOAD DE ARQUIVOS
# ============================================
MAX_FILE_SIZE=5242880
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_FILE=logs/app.log
